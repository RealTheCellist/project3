# =========================
# Sumpyo Backend .env template
# =========================

# --- Text signal model (optional, default = rule-based) ---
TEXT_SIGNAL_MODEL_ENABLED=false
TEXT_SIGNAL_MODEL_NAME=joeddav/xlm-roberta-large-xnli
TEXT_SIGNAL_HYPOTHESIS_TEMPLATE=This text indicates {} state.
TEXT_SIGNAL_MAX_CHARS=1200

# --- STT runtime ---
STT_PROVIDER=faster_whisper
STT_PROFILE=balanced
STT_RECOMMENDATION_FILE=data/stt_recommendation.json

# --- Whisper backend ---
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=3
WHISPER_VAD_FILTER=true

